# Secrets — nunca commitar
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Dados gerados
data/*.json
!data/.gitkeep
# Exceção: precisa persistir entre execuções do GitHub Actions para acumular
# histórico de Stories (a API só expõe stories ativos, até 24h após publicar).
!data/meta_stories_history.json
# Exceção: curadoria manual (tags de conteúdo e dados de creators) que não vem
# de nenhuma API — precisa ficar versionada, não é "dado gerado".
!data/content_tags.json
!data/creators.json

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
