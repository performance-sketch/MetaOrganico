# Secrets — nunca commitar
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Dados gerados
data/*.json
!data/.gitkeep
# Exceção: precisa persistir entre execuções do GitHub Actions para acumular
# histórico de Stories (a API só expõe stories ativos, até 24h após publicar).
!data/meta_stories_history.json
# Exceção: mesma razão — as séries diárias de conta (reach, seguidores,
# visualizações etc.) só trazem uma janela recente por execução, precisam
# acumular entre execuções do GitHub Actions.
!data/meta_account_timeseries.json
# Exceção: curadoria manual (tags de conteúdo e dados de creators) que não vem
# de nenhuma API — precisa ficar versionada, não é "dado gerado".
!data/content_tags.json
!data/creators.json
# Exceção: dado importado manualmente de planilhas (Business Suite/Ads Manager),
# também não vem de nenhuma API — precisa persistir entre execuções.
!data/manual_content.json

# Exports brutos (CSV) usados só como entrada do importador — não versionados,
# o dado normalizado fica em data/manual_content.json.
data/manual_exports/

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
