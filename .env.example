# ── Meta (Facebook + Instagram) ────────────────────────────────────────────────
# Token de usuário/sistema de longa duração, com permissões:
#   pages_show_list, pages_read_engagement, instagram_basic,
#   instagram_manage_insights, read_insights
# Gere em: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=TODO_your_long_lived_access_token
META_API_VERSION=v19.0
# Não é usado nas chamadas atuais do conector, mas fica salvo para uso futuro
# (ex.: appsecret_proof, renovação de token)
META_APP_SECRET=TODO_your_app_secret

# Opcional: se não definido, o conector auto-descobre via /me/accounts
META_PAGE_ID=
META_IG_ACCOUNT_ID=

# Quantos dias de posts orgânicos buscar por padrão. A partir da 2ª execução,
# fetch_meta_organic.py funde por id com o que já está salvo em
# data/meta_organic.json — então esse valor só controla a janela de busca de
# CADA execução, não o histórico total acumulado (que só cresce, nunca encolhe).
# Para um backfill único (ex.: trazer tudo desde 01/01/2025), rode uma vez com
# um valor bem maior, ex.: ORGANIC_LOOKBACK_DAYS=600 python scripts/fetch_meta_organic.py
ORGANIC_LOOKBACK_DAYS=90
